# Bot Mode Configuration
BOT_MODE=polling  # "polling" for development, "webhook" for production
WEBHOOK_URL=https://theme-salad-hurt.ngrok-free.dev  # e.g., https://yourdomain.com (required for webhook mode)
WEBHOOK_PATH=/webhook  # Webhook endpoint path
WEBHOOK_PORT=8443  # Port for webhook server
WEBHOOK_SECRET=fajdjfhairioaefjnjdan3875908247  # Secret token for webhook security (recommended for production)

# Telegram Bot Configuration
BOT_TOKEN=your_bot_token_here

# Database Configuration
# External database connection. URL-encode special characters in user/password.
DATABASE_URL=mysql+pymysql://<user>:<password>@<host>:<port>/<database>

# Tracking Configuration
CHECK_INTERVAL_MINUTES=5
LOG_LEVEL=INFO
DEFAULT_LANG=vi

# Monitoring Configuration
SENTRY_DSN=
SENTRY_SEND_DEFAULT_PII=true