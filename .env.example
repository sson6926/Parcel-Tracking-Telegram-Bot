# Telegram Bot Configuration
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# Database Configuration
DATABASE_URL=sqlite:///./tracking.db
# Or with PostgreSQL: postgresql://user:password@localhost:5432/tracking_db

# Logging Configuration
LOG_LEVEL=INFO

# Internationalization
DEFAULT_LANG=vi

# Tracking Configuration
CHECK_INTERVAL_MINUTES=5

# ============================================================================
# WEBHOOK CONFIGURATION (Optional - for webhook mode instead of polling)
# ============================================================================
# Leave all WEBHOOK_* variables unset to use polling mode (default)

# Public domain/IP where the bot will receive updates from Telegram
# Required for webhook mode. Examples:
#   - example.com
#   - 123.45.67.89
#   - bot.example.com (subdomain)
# WEBHOOK_DOMAIN=example.com

# Local port to listen on (default: 8443)
# Must be HTTPS port or accept HTTP with reverse proxy
# WEBHOOK_PORT=8443

# Local host to bind to (default: 0.0.0.0)
# Use 127.0.0.1 if behind reverse proxy like nginx
# WEBHOOK_HOST=0.0.0.0

# URL path for webhook endpoint (default: /webhook)
# Full webhook URL will be: https://{WEBHOOK_DOMAIN}{WEBHOOK_PATH}
# WEBHOOK_PATH=/webhook

# SSL Certificate and Key paths (optional)
# If not provided, telegram.ext will handle HTTPS automatically
# WEBHOOK_CERT=/path/to/certificate.pem
# WEBHOOK_KEY=/path/to/private_key.pem

# ============================================================================
# WEBHOOK SETUP INSTRUCTIONS
# ============================================================================
# 
# 1. POLLING MODE (Default - easiest for development):
#    - Leave all WEBHOOK_* variables unset
#    - Bot continuously asks Telegram for updates
#    - Works anywhere, less efficient, no public URL needed
#    
# 2. WEBHOOK MODE (Better for production):
#    
#    Quick Test with ngrok:
#    $ ngrok http 8443
#    Set WEBHOOK_DOMAIN to ngrok URL (e.g., xxxxx.ngrok.io)
#    $ python scripts/webhook_setup.py setup
#    $ python -m bot.main
#    
#    Production with your domain:
#    Set WEBHOOK_DOMAIN to your domain
#    Configure reverse proxy (nginx) if needed
#    $ python scripts/webhook_setup.py setup
#    $ python -m bot.main
# 
# Webhook Setup Commands:
#    $ python scripts/webhook_setup.py setup  # Setup webhook
#    $ python scripts/webhook_setup.py delete # Switch back to polling
#    $ python scripts/webhook_setup.py info   # Show current status
#
# ============================================================================
